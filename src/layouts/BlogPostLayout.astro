---
// src/layouts/BlogPostLayout.astro
interface Props {
  frontmatter?: {
    title?: string;
    pubDate?: string;
    author?: string;
    category?: 'Networking' | 'AI' | 'Robotics';
  };
}

const { frontmatter = {} } = Astro.props;
const category = frontmatter?.category;
---

<html lang="si">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter?.title ?? "Tech Blog"}</title>
    <!-- Modern Premium Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="navbar-header">
      <div class="navbar-container">
        <a href="/" class="logo-link">
          <span class="logo-icon">🤖</span> DevBots<span class="logo-accent">2</span>
        </a>
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/categories/Networking">Networking</a>
          <a href="/categories/AI">AI</a>
          <a href="/categories/Robotics">Robotics</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <nav class="back-nav">
        <a href="/" class="back-link">← ආපසු මුල් පිටුවට (Go Back)</a>
      </nav>

      <article class={`blog-article ${category ? `category-${category.toLowerCase()}` : ''}`}>
        {category && (
          <div class="category-badge-wrapper">
            <span class={`badge badge-${category.toLowerCase()}`}>{category}</span>
          </div>
        )}
        
        <h1 class="post-title">{frontmatter?.title ?? "Untitled Post"}</h1>

        <div class="meta-container">
          {frontmatter?.pubDate && (
            <div class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
              </svg>
              <span>{frontmatter.pubDate}</span>
            </div>
          )}
          {frontmatter?.author && (
            <div class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
              </svg>
              <span>{frontmatter.author}</span>
            </div>
          )}
        </div>

        <hr class="divider" />

        <div class="content-body">
          <slot />
        </div>
      </article>
    </main>

    <footer class="blog-footer">
      <div class="footer-container">
        <p>&copy; {new Date().getFullYear()} DevBots2 Blog. All rights reserved.</p>
        <p class="footer-subtext">Exploring AI, Robotics, and Networking in සිංහල & English</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Base reset and dark theme styles */
  :root {
    --bg-dark: #090d16;
    --bg-dark-accent: #0f172a;
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
    --border-color: rgba(255, 255, 255, 0.08);
    
    /* Category Colors */
    --color-ai: #a78bfa;
    --color-ai-rgb: 167, 139, 250;
    --color-net: #38bdf8;
    --color-net-rgb: 56, 189, 248;
    --color-rob: #fb923c;
    --color-rob-rgb: 251, 146, 60;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background-color: var(--bg-dark);
    background-image: 
      radial-gradient(at 0% 0%, rgba(167, 139, 250, 0.05) 0px, transparent 50%),
      radial-gradient(at 100% 0%, rgba(56, 189, 248, 0.05) 0px, transparent 50%);
    background-attachment: fixed;
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  /* Header styles */
  .navbar-header {
    background-color: rgba(9, 13, 22, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-link {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: transform 0.2s ease;
  }

  .logo-link:hover {
    transform: scale(1.02);
  }

  .logo-icon {
    font-size: 1.6rem;
  }

  .logo-accent {
    color: var(--color-ai);
    background: linear-gradient(135deg, var(--color-ai), var(--color-net));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease, transform 0.2s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-links a:hover {
    color: #fff;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-ai), var(--color-net));
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* Main container */
  .main-content {
    flex: 1;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .back-nav {
    margin-bottom: 2rem;
  }

  .back-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .back-link:hover {
    color: #fff;
    transform: translateX(-4px);
  }

  /* Article styling */
  .blog-article {
    background-color: rgba(15, 23, 42, 0.4);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
    position: relative;
    overflow: hidden;
  }

  .blog-article::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--border-color);
  }

  .blog-article.category-ai::before {
    background: linear-gradient(90deg, var(--color-ai), #c084fc);
  }

  .blog-article.category-networking::before {
    background: linear-gradient(90deg, var(--color-net), #0ea5e9);
  }

  .blog-article.category-robotics::before {
    background: linear-gradient(90deg, var(--color-rob), #f97316);
  }

  .category-badge-wrapper {
    margin-bottom: 1.5rem;
  }

  .badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
  }

  .badge-ai {
    background-color: rgba(var(--color-ai-rgb), 0.15);
    color: var(--color-ai);
    border: 1px solid rgba(var(--color-ai-rgb), 0.3);
  }

  .badge-networking {
    background-color: rgba(var(--color-net-rgb), 0.15);
    color: var(--color-net);
    border: 1px solid rgba(var(--color-net-rgb), 0.3);
  }

  .badge-robotics {
    background-color: rgba(var(--color-rob-rgb), 0.15);
    color: var(--color-rob);
    border: 1px solid rgba(var(--color-rob-rgb), 0.3);
  }

  .post-title {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.25;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .meta-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .meta-item svg {
    opacity: 0.7;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2rem 0;
  }

  /* Content Formatting inside posts */
  .content-body {
    font-size: 1.1rem;
    color: #cbd5e1;
  }

  .content-body p {
    margin-bottom: 1.5rem;
  }

  .content-body h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.75rem;
    color: #fff;
    margin: 2.5rem 0 1rem;
  }

  .content-body h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    color: #fff;
    margin: 2rem 0 1rem;
  }

  .content-body ul, .content-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .content-body li {
    margin-bottom: 0.5rem;
  }

  .content-body blockquote {
    border-left: 4px solid var(--color-ai);
    background-color: rgba(255, 255, 255, 0.03);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: #e2e8f0;
  }
  
  .blog-article.category-networking blockquote {
    border-left-color: var(--color-net);
  }

  .blog-article.category-robotics blockquote {
    border-left-color: var(--color-rob);
  }

  /* Footer styles */
  .blog-footer {
    background-color: rgba(9, 13, 22, 0.95);
    border-top: 1px solid var(--border-color);
    padding: 3rem 2rem;
    text-align: center;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .blog-footer p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-subtext {
    font-size: 0.85rem !important;
    opacity: 0.7;
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .navbar-container {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }
    
    .main-content {
      padding: 1.5rem 1rem;
    }
    
    .blog-article {
      padding: 1.75rem;
      border-radius: 12px;
    }

    .post-title {
      font-size: 1.85rem;
    }
  }
</style>
