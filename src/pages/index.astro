---
// Import your layout component
import BaseLayout from '../layouts/BlogPostLayout.astro';
import { getCollection } from 'astro:content';

// Fetch your blog posts
const allPosts = await getCollection('posts');
const pageTitle = "Tech Insights | DevBots2 Blog";

// Sort posts by date (latest first)
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Categories defined
const categories = ['Networking', 'AI', 'Robotics'] as const;
---

<BaseLayout frontmatter={{ title: pageTitle }}>
  <section class="hero-section">
    <div class="hero-badge">Welcome to DevBots2 Blog</div>
    <h1 class="hero-title">Discover the Future of <br/><span class="gradient-text">Technology & Engineering</span></h1>
    <p class="hero-subtitle">Exploring computer networking, artificial intelligence, and advanced robotics.</p>
    
    <div class="category-quick-links">
      {categories.map((cat) => {
        const count = sortedPosts.filter(p => p.data.category === cat).length;
        return (
          <a href={`${import.meta.env.BASE_URL}categories/${cat}`} class={`quick-link-btn btn-${cat.toLowerCase()}`}>
            <span class="btn-dot"></span>
            <span class="btn-name">{cat}</span>
            <span class="btn-count">{count}</span>
          </a>
        );
      })}
    </div>
  </section>

  <div class="sections-container">
    {categories.map((category) => {
      const postsInCategory = sortedPosts.filter(post => post.data.category === category);
      
      return (
        <section class={`category-section section-${category.toLowerCase()}`}>
          <div class="section-header">
            <h2 class="section-title">
              <span class="title-accent"></span>
              {category} Related Posts
            </h2>
            <a href={`${import.meta.env.BASE_URL}categories/${category}`} class="view-all-link">
              View All {category} →
            </a>
          </div>

          {postsInCategory.length > 0 ? (
            <div class="posts-grid">
              {postsInCategory.map((post) => (
                <article class="post-card">
                  <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`} class="card-inner-link">
                    <div class="card-header">
                      <span class={`card-badge badge-${category.toLowerCase()}`}>{category}</span>
                      <span class="card-date">{post.data.pubDate}</span>
                    </div>
                    <h3 class="card-title">{post.data.title}</h3>
                    <div class="card-footer">
                      <span class="card-author">By {post.data.author}</span>
                      <span class="read-more">Read Post →</span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <p>No posts published in this category yet. Stay tuned!</p>
            </div>
          )}
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  /* Hero Styles */
  .hero-section {
    text-align: center;
    padding: 3rem 0 4rem;
  }

  .hero-badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ai);
    background: rgba(var(--color-ai-rgb), 0.1);
    border: 1px solid rgba(var(--color-ai-rgb), 0.2);
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: 'Outfit', sans-serif;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-ai) 0%, var(--color-net) 50%, var(--color-rob) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  /* Quick links styling */
  .category-quick-links {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .quick-link-btn {
    font-family: 'Outfit', sans-serif;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.25rem;
    background-color: rgba(15, 23, 42, 0.4);
    border: 1px solid var(--border-color);
    border-radius: 100px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .btn-count {
    font-size: 0.8rem;
    padding: 0.1rem 0.5rem;
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    color: var(--text-secondary);
  }

  .btn-ai .btn-dot { background-color: var(--color-ai); }
  .btn-networking .btn-dot { background-color: var(--color-net); }
  .btn-robotics .btn-dot { background-color: var(--color-rob); }

  .quick-link-btn:hover {
    background-color: rgba(15, 23, 42, 0.8);
    transform: translateY(-2px);
  }

  .btn-ai:hover { border-color: rgba(var(--color-ai-rgb), 0.5); box-shadow: 0 0 15px rgba(var(--color-ai-rgb), 0.15); }
  .btn-networking:hover { border-color: rgba(var(--color-net-rgb), 0.5); box-shadow: 0 0 15px rgba(var(--color-net-rgb), 0.15); }
  .btn-robotics:hover { border-color: rgba(var(--color-rob-rgb), 0.5); box-shadow: 0 0 15px rgba(var(--color-rob-rgb), 0.15); }

  /* Sections Container */
  .sections-container {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 2rem;
  }

  .category-section {
    border-top: 1px solid var(--border-color);
    padding-top: 3rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .title-accent {
    width: 6px;
    height: 24px;
    border-radius: 100px;
  }

  .section-ai .title-accent { background: var(--color-ai); }
  .section-networking .title-accent { background: var(--color-net); }
  .section-robotics .title-accent { background: var(--color-rob); }

  .view-all-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .view-all-link:hover {
    color: #fff;
    transform: translateX(4px);
  }

  /* Grid and Cards */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background-color: rgba(15, 23, 42, 0.3);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-inner-link {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    height: 100%;
    text-decoration: none;
    color: var(--text-primary);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .card-badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-date {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
    color: #fff;
    margin-bottom: 2rem;
    flex: 1;
    transition: color 0.2s ease;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .read-more {
    font-weight: 600;
    color: var(--text-primary);
    transition: transform 0.2s ease;
  }

  /* Card Hover Animations */
  .post-card:hover {
    transform: translateY(-6px);
    background-color: rgba(15, 23, 42, 0.6);
  }

  .section-ai .post-card:hover {
    border-color: rgba(var(--color-ai-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-ai-rgb), 0.2);
  }

  .section-networking .post-card:hover {
    border-color: rgba(var(--color-net-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-net-rgb), 0.2);
  }

  .section-robotics .post-card:hover {
    border-color: rgba(var(--color-rob-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-rob-rgb), 0.2);
  }

  .post-card:hover .card-title {
    color: #fff;
  }

  .section-ai .post-card:hover .card-title { color: var(--color-ai); }
  .section-networking .post-card:hover .card-title { color: var(--color-net); }
  .section-robotics .post-card:hover .card-title { color: var(--color-rob); }

  .post-card:hover .read-more {
    transform: translateX(4px);
  }

  /* Empty state & responsive */
  .empty-state {
    text-align: center;
    padding: 3rem;
    background-color: rgba(15, 23, 42, 0.15);
    border: 1px dashed var(--border-color);
    border-radius: 16px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>