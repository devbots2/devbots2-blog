---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  
  // Get all unique categories from the posts
  const uniqueCategories = [...new Set(allPosts.map((post) => post.data.category).filter(Boolean))];

  return uniqueCategories.map((category) => {
    const filteredPosts = allPosts.filter((post) => post.data.category === category);
    return {
      params: { category },
      props: { posts: filteredPosts },
    };
  });
}

const { category } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date (latest first)
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout frontmatter={{ title: `${category} Articles | DevBots2` }}>
  <div class={`category-page category-${category.toLowerCase()}`}>
    <div class="category-header">
      <span class="back-link-wrapper">
        <a href={import.meta.env.BASE_URL} class="back-to-home">← Back to Homepage</a>
      </span>
      <h1 class="category-title">
        <span class="title-accent"></span>
        {category} Related Articles
      </h1>
      <p class="category-desc">
        All articles tagged under the <span class="tag-highlight">{category}</span> category.
      </p>
    </div>

    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <article class="post-card">
          <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`} class="card-inner-link">
            <div class="card-header">
              <span class={`card-badge badge-${category.toLowerCase()}`}>{category}</span>
              <span class="card-date">{post.data.pubDate}</span>
            </div>
            <h3 class="card-title">{post.data.title}</h3>
            <div class="card-footer">
              <span class="card-author">By {post.data.author}</span>
              <span class="read-more">Read Post →</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .category-page {
    padding: 1rem 0;
  }

  .category-header {
    margin-bottom: 3rem;
  }

  .back-link-wrapper {
    display: block;
    margin-bottom: 1.5rem;
  }

  .back-to-home {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-to-home:hover {
    color: #fff;
  }

  .category-title {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .title-accent {
    width: 8px;
    height: 32px;
    border-radius: 100px;
  }

  .category-ai .title-accent { background: var(--color-ai); }
  .category-networking .title-accent { background: var(--color-net); }
  .category-robotics .title-accent { background: var(--color-rob); }

  .category-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .tag-highlight {
    font-weight: 600;
    color: #fff;
  }

  .category-ai .tag-highlight { color: var(--color-ai); }
  .category-networking .tag-highlight { color: var(--color-net); }
  .category-robotics .tag-highlight { color: var(--color-rob); }

  /* Grid and Cards */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background-color: rgba(15, 23, 42, 0.3);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-inner-link {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    height: 100%;
    text-decoration: none;
    color: var(--text-primary);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .card-badge {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-date {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
    color: #fff;
    margin-bottom: 2rem;
    flex: 1;
    transition: color 0.2s ease;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .read-more {
    font-weight: 600;
    color: var(--text-primary);
    transition: transform 0.2s ease;
  }

  /* Card Hover Animations */
  .post-card:hover {
    transform: translateY(-6px);
    background-color: rgba(15, 23, 42, 0.6);
  }

  .category-ai .post-card:hover {
    border-color: rgba(var(--color-ai-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-ai-rgb), 0.2);
  }

  .category-networking .post-card:hover {
    border-color: rgba(var(--color-net-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-net-rgb), 0.2);
  }

  .category-robotics .post-card:hover {
    border-color: rgba(var(--color-rob-rgb), 0.4);
    box-shadow: 0 10px 25px -10px rgba(var(--color-rob-rgb), 0.2);
  }

  .post-card:hover .card-title {
    color: #fff;
  }

  .category-ai .post-card:hover .card-title { color: var(--color-ai); }
  .category-networking .post-card:hover .card-title { color: var(--color-net); }
  .category-robotics .post-card:hover .card-title { color: var(--color-rob); }

  .post-card:hover .read-more {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .category-title {
      font-size: 2rem;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
